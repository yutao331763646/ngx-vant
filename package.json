{
  "name": "ngx-vant",
  "version": "0.1.1",
  "scripts": {
    "ng": "ng",
    "bootstrap": "yarn || npm i",
    "start": "ng serve",
    "doc": "ng serve  --port  4201 ",
    "gen:doc": "node ./scripts/genDoc",
    "doc:build": "ng build --configuration production",
    "test": "ng test",
    "lint": "ng lint",
    "build_lib": "ng build  ngx-vant",
    "npm_pack": "cd ./dist/ngx-vant && npm pack",
    "copy_style": "node ./scripts/copyStyle.js",
    "package": "npm run build_lib && npm run npm_pack && npm run copy_style"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@types/fs-extra": "^11.0.4",
    "@vant/icons": "^3.0.2",
    "@vant/touch-emulator": "^1.5.0",
    "fs-extra": "^11.3.4",
    "highlight.js": "^11.11.1",
    "html-loader": "^5.1.0",
    "markdown-loader": "^8.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.1",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^22.10.5",
    "jasmine-core": "~5.5.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.0",
    "ts-node": "~10.9.2",
    "typescript": "~5.9.2"
  }
}
